# Pantry Pulse Orchestrator - Native App Configuration
#
# This file shows what environment variables are needed.
# DO NOT commit your actual .env.local file to git.
#
# Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in the actual values for your environment
# 3. Never commit .env.local to git

# Backend API URL
# The native app communicates with the backend API here.
#
# Choose based on your environment:
# - Local development:  http://localhost:8000/api
# - On same network:    http://192.168.1.100:8000/api  (replace with your IP)
# - Staging server:     https://staging-api.example.com/api
# - Production:         https://api.example.com/api
EXPO_PUBLIC_API_BASE_URL=https://pantry-pulse-orchestrator-vody.onrender.com/api
