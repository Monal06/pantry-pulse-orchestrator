# Production Environment Variables
# Copy this to your hosting platform's environment settings

# REQUIRED: Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: Database (if using Supabase)
SUPABASE_URL=
SUPABASE_KEY=

# Environment
ENVIRONMENT=production

# CORS Origins (comma-separated URLs)
# Example: https://pantry-pulse-web.onrender.com,https://pantry-pulse-web.vercel.app
CORS_ORIGINS=*

# Model fallback chain
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-pro,gemini-2.5-flash-lite,gemini-3.1-flash-preview,gemini-3.1-pro-preview,gemini-2.0-flash,gemini-flash-latest

# Features
OPEN_FOOD_FACTS_ENABLED=true

